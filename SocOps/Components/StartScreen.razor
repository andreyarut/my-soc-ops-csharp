<div class="sw-app sw-screen flex flex-col items-center justify-center min-h-full p-6">
    <div class="text-center max-w-sm sw-crawl">
        <h1 class="sw-title text-4xl font-bold text-gray-900 mb-2">Galactic Social Ops</h1>
        <p class="sw-subtitle text-lg mb-8">Cantina Bingo Protocol</p>

        <div class="sw-panel rounded-lg p-6 mb-8">
            <h2 class="sw-brand font-semibold text-gray-800 mb-3">Mission Briefing</h2>
            <ul class="text-left text-gray-600 text-sm space-y-2">
                <li>• Find crew members matching each holo-prompt</li>
                <li>• Mark a square after each successful encounter</li>
                <li>• Secure 5 in a line to claim sector victory</li>
            </ul>
        </div>

        <button @onclick="OnStart"
                class="w-full bg-accent sw-btn-primary font-semibold py-4 px-8 text-lg active:bg-accent-light transition-colors sw-brand">
            Launch Mission
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
