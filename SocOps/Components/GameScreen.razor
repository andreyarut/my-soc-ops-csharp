@using SocOps.Models

<div class="sw-app sw-screen flex flex-col min-h-full">
    <header class="flex items-center justify-between p-3 sw-panel-soft border-b border-gray-200">
        <button @onclick="OnReset" class="sw-btn-ghost text-sm px-3 py-1.5 active:bg-gray-100">
            ← Exit Sector
        </button>
        <h1 class="sw-brand font-bold text-gray-900">Rebel Grid</h1>
        <div class="w-16"></div>
    </header>

    <p class="text-center text-gray-500 text-sm py-2 px-4 sw-crawl">
        Mark a tile when you recruit an ally matching that transmission.
    </p>

    @if (HasBingo)
    {
        <div class="bg-amber-100 text-amber-800 text-center py-2 font-semibold text-sm sw-brand">
            Signal Locked: Mission Line Complete
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-3">
        <div class="sw-board-shell w-full max-w-md mx-auto sw-crawl">
            <BingoBoard Board="@Board" WinningSquareIds="@WinningSquareIds" OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
