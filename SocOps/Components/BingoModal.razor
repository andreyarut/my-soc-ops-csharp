<div class="sw-overlay fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="sw-modal rounded-xl p-6 max-w-xs w-full text-center shadow-xl animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4 sw-pulse">⚔️</div>
        <h2 class="sw-brand text-3xl font-bold text-amber-500 mb-2">Bingo Confirmed</h2>
        <p class="text-gray-600 mb-6">You aligned a full rebel channel.</p>

        <button @onclick="OnDismiss"
                class="w-full bg-accent sw-btn-primary font-semibold py-3 px-6 active:bg-accent-light transition-colors sw-brand">
            Continue Patrol
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
